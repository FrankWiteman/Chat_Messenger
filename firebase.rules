rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the current user matches the requested userId
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if current user is listed in the 'participants' array of a document
    function isParticipant(resourceData) {
      return isSignedIn() && (request.auth.uid in resourceData.participants);
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Anyone signed in can read profiles (needed for Global PIN search and contact resolution)
      allow read: if isSignedIn();
      
      // Only the account owner can update their profile (status, avatar, name, online presence)
      allow write: if isUser(userId);

      // Roster Subcollection (Friends list)
      match /roster/{friendId} {
        // Only the user can see or modify their own contact list
        allow read, write: if isUser(userId);
      }
    }

    // --- Friend Requests ---
    match /friend_requests/{requestId} {
      // Can read if you are the sender OR the recipient
      allow read: if isSignedIn() && (
        resource.data.fromUser.id == request.auth.uid || 
        resource.data.toUserId == request.auth.uid
      );
      
      // Can create if you are the sender
      allow create: if isSignedIn() && request.resource.data.fromUser.id == request.auth.uid;
      
      // Can delete/update (accept/reject) if involved
      allow update, delete: if isSignedIn() && (
        resource.data.fromUser.id == request.auth.uid || 
        resource.data.toUserId == request.auth.uid
      );
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      // READ: Only participants can see the chat
      allow read: if isParticipant(resource.data);
      
      // CREATE: Must include yourself as a participant
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      
      // UPDATE: Participants can update (typing status, last message, unread counts)
      allow update: if isParticipant(resource.data);
      
      // DELETE: Participants can delete (though usually handled via field updates in real apps)
      allow delete: if isParticipant(resource.data);

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        // Fetch the parent chat document to check participants
        function getParentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }

        // READ: Must be a participant of the parent chat
        allow read: if isParticipant(getParentChat());
        
        // CREATE: Must be a participant of parent chat AND the sender must be you
        allow create: if isParticipant(getParentChat()) && 
                         request.resource.data.senderId == request.auth.uid;
        
        // UPDATE: Participants can update (e.g., marking as read)
        allow update: if isParticipant(getParentChat());
      }
    }

    // --- Calls Collection ---
    match /calls/{callId} {
      // Basic signaling rules: Caller or Callee can read/write
      allow read, update, delete: if isSignedIn() && (
        resource.data.callerId == request.auth.uid || 
        resource.data.calleeId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.callerId == request.auth.uid;
    }
  }
}